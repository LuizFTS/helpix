# Copie este arquivo para ".env" (sem o .example) na raiz do projeto e
# preencha com os valores do SEU projeto Firebase.
#
# Onde encontrar: Console do Firebase > seu projeto > ⚙️ Configurações
# do projeto > aba "Geral" > seção "Seus apps" > app Web > "Config".
#
# IMPORTANTE: reinicie o Metro com `npx expo start -c` depois de criar
# ou editar este arquivo — variáveis de ambiente só são lidas na
# inicialização do bundler.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=